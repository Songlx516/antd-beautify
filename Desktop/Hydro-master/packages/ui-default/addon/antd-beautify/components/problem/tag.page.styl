/* AntD-Beautify - dtoj.team 风格标签样式 */
/* 圆角矩形按钮风格：淡色背景 + 同色系边框 */

.problem__tags
  margin: 0 !important
  padding: 0 !important
  list-style: none !important
  font-size: 0
  word-break: keep-all
  display: flex
  flex-wrap: wrap
  gap: 6px
  align-items: center
  line-height: 1

.problem__tag
  display: inline-flex
  align-items: center
  justify-content: center
  vertical-align: top
  margin: 0 !important
  padding: 0 !important

.problem__tag-item
  padding: 4px 12px !important
  margin-left: 0
  margin-bottom: 4px
  margin-right: 4px
  display: inline-flex
  flex-direction: row
  align-items: center
  border: 1px solid #d9d9d9
  border-radius: 6px
  font-size: 12px
  font-weight: 500
  letter-spacing: 0.2px
  line-height: 18px
  max-width: 100%
  min-height: 24px
  min-width: auto
  position: relative
  background-color: #f5f5f5
  color: #5D6C7B
  transition: all 150ms ease
  box-shadow: none
  height: auto
  overflow: hidden
  text-overflow: ellipsis
  white-space: nowrap
  text-decoration: none
  &:hover
    text-decoration: none
    filter: brightness(0.95)
  > span
    display: flex
    align-items: center
  > *
    flex-grow: 0
    flex-shrink: 0
    margin-right: 6px
  &:before,
  > *
    margin-right: 4px
  > :last-child
    margin-right: 0

.problem__tag-link
  padding: 4px 12px !important
  margin-left: 0
  margin-bottom: 4px
  margin-right: 4px
  display: inline-flex
  align-items: center
  justify-content: center
  overflow: hidden
  text-overflow: ellipsis
  white-space: nowrap
  max-width: 250px
  min-height: 24px
  line-height: 18px
  height: auto
  border-radius: 6px
  border: 1px solid #d9d9d9
  font-size: 12px
  font-weight: 500
  letter-spacing: 0.2px
  transition: all 150ms ease
  text-decoration: none
  box-shadow: none
  position: relative
  background-color: #f5f5f5
  color: #5D6C7B
  &:hover
    filter: brightness(0.95)

html:not(.theme--dark) .problem__tag-link
  color: #5D6C7B !important
  background-color: #f5f5f5 !important
  border: 1px solid #d9d9d9 !important

.col--problem-name
  .problem__tags
    float: right
  .problem__tag
    margin: 0 2px 0 0 !important

