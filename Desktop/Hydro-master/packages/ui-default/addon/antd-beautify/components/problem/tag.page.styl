.problem__tags
  margin: 0
  padding: 0
  list-style: none
  font-size: 0
  word-break: keep-all
  display: flex
  flex-wrap: wrap
  gap: 4px
.problem__tag
  display: inline-block
  vertical-align: top
  margin: 0
  padding: 0
.problem__tag-item
  display: inline-flex !important
  align-items: center !important
  justify-content: center !important
  padding: 0px 6px !important
  overflow: hidden !important
  text-overflow: ellipsis !important
  white-space: nowrap !important
  max-width: 220px !important
  height: 22px !important
  line-height: 22px !important
  border-radius: 6px !important
  font-size: 11px !important
  font-weight: 500 !important
  transition: all 0.2s ease !important
  text-decoration: none !important
  border: 1px solid rgba(148, 163, 184, 0.56) !important
  background: rgb(238, 242, 247) !important
  box-shadow: rgba(255, 255, 255, 0.72) 0px 1px 0px 0px inset !important
  color: rgb(39, 52, 73) !important
  cursor: pointer !important
  min-height: 22px !important
  min-width: auto !important
  margin-left: 4px !important
  margin-bottom: 4px !important
  box-sizing: border-box !important
  flex-direction: row !important
  &:hover
    transform: translateY(-1px) !important
    box-shadow: rgba(255, 255, 255, 0.72) 0px 1px 0px 0px inset, 0 3px 8px rgba(0, 0, 0, 0.12) !important
.problem__tag-link
  display: inline-flex !important
  align-items: center !important
  justify-content: center !important
  padding: 0px 6px !important
  overflow: hidden !important
  text-overflow: ellipsis !important
  white-space: nowrap !important
  max-width: 220px !important
  height: 22px !important
  border-radius: 6px !important
  font-size: 11px !important
  font-weight: 500 !important
  transition: all 0.2s ease !important
  text-decoration: none !important
  border: 1px solid rgba(148, 163, 184, 0.56) !important
  background: rgb(238, 242, 247) !important
  box-shadow: rgba(255, 255, 255, 0.72) 0px 1px 0px 0px inset !important
  color: rgb(39, 52, 73) !important
  cursor: pointer !important
  &:hover
    transform: translateY(-1px) !important
    box-shadow: rgba(255, 255, 255, 0.72) 0px 1px 0px 0px inset, 0 3px 8px rgba(0, 0, 0, 0.12) !important
.col--problem-name
  .problem__tags
    float: right
  .problem__tag
    margin: 0 4px 0 0
  a,
  button.link
    font-size: 15px !important
    font-weight: 500 !important
    margin: 0 4px 0 0