.discussion-node-tag
  font-size: rem($font-size-small)
  display: inline-block
  line-height: rem(22px)
  padding: rem(0 10px)
  vertical-align: middle
  border-radius: rem(12px)
  border: 1px solid #d1d5db
  background: #f9fafb
  color: #374151

  &:hover
    background: #3b82f6
    color: #FFF !important
    text-decoration: none
    border-color: #3b82f6

  .icon
    margin-right: rem(5px)
