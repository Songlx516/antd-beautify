.scratchpad__toolbar
  background: #f5f5f5
  padding: rem(8px)
  font-size: rem($font-size-small)
  font-weight: normal
  border-bottom: 1px solid #e8e8e8
  border-radius: 6px 6px 0 0

.scratchpad__toolbar__item
  margin-right: rem(5px)

  .select
    margin: 0
    height: auto
    line-height: 1
    border-radius: 6px
    border: 1px solid #d9d9d9
    transition: all 0.3s
    
    &:focus
      border-color: #1890ff
      box-shadow: 0 0 0 2px rgba(24, 144, 255, 0.2)

.scratchpad__toolbar__button
  padding: 4px 12px
  font-size: rem($font-size-small)
  font-weight: 400
  background: #fff
  border: 1px solid #d9d9d9
  color: rgba(0, 0, 0, 0.85)
  outline: 0
  transition: all 0.3s cubic-bezier(0.645, 0.045, 0.355, 1)
  border-radius: 6px
  display: inline-flex
  align-items: center
  justify-content: center
  
  &>div
    display: flex
    flex-direction: row
    align-items: center

  &.enabled
    cursor: pointer

  .icon
    font-size: rem($font-size-icon)
    margin-right: 4px

  &.enabled:hover
    color: #1890ff
    border-color: #1890ff
    background: #e6f7ff

  &.activated
    color: #fff !important
    background: #1890ff !important
    border-color: #1890ff !important

  &.disabled
    pointer-events: none
    opacity: 0.4

.scratchpad__toolbar__split
  width: 1px
  height: 1rem
  background: #e8e8e8

.scratchpad__toolbar__pretest.enabled:hover .icon
  color: red

.scratchpad__toolbar__submit.enabled:hover .icon
  color: green