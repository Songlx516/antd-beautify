/* AntD-Beautify + Meta Store Theme - Problem Tag Styles */
/* 每个标签独立配色 - 全部不同 */

.problem__tags
  margin: 0 !important
  padding: 0 !important
  list-style: none !important
  font-size: 0
  word-break: keep-all
  display: flex
  flex-wrap: wrap
  gap: 4px
  align-items: center
  line-height: 1

.problem__tag
  display: inline-flex
  align-items: center
  justify-content: center
  vertical-align: top
  margin: 0 !important
  padding: 0 !important

.problem__tag-item
  padding: 2px 10px !important
  margin-left: rem(2px)
  margin-bottom: rem(3px)
  display: inline-flex
  flex-direction: row
  align-items: center
  border: none
  border-radius: 6px
  box-shadow: none
  font-size: 12px
  font-weight: 500
  letter-spacing: -0.14px
  line-height: 16px
  max-width: 100%
  min-height: 22px
  min-width: auto
  position: relative
  background-color: #F1F4F7
  color: #5D6C7B
  transition: all 180ms ease
  &:hover
    text-decoration: none
    transform: scale(1.03)
  > span
    display: flex
    align-items: center
  > *
    flex-grow: 0
    flex-shrink: 0
    margin-right: 6px
  &:before,
  > *
    margin-right: 4px
  > :last-child
    margin-right: 0
  &:focus
    outline: hsl(214, 89%, 52%) solid 2px
    outline-offset: 0
    -moz-outline-radius: 4px
  &.interactive
    cursor: pointer

.problem__tag-link
  display: inline-flex
  align-items: center
  justify-content: center
  padding: 2px 10px
  overflow: hidden
  text-overflow: ellipsis
  white-space: nowrap
  max-width: rem(250px)
  min-height: 22px
  line-height: 16px
  height: auto
  border-radius: 6px
  border: 1.5px solid currentColor
  font-size: 11px
  font-weight: 500
  letter-spacing: -0.14px
  transition: all 180ms ease
  text-decoration: none

  &:hover
    filter: brightness(0.85) saturate(1.2) !important
    box-shadow: 0 2px 8px rgba(0,0,0,0.25) !important
    transform: scale(1.05)

html:not(.theme--dark) .problem__tag-link
  color: #FFFFFF !important
  border: none !important

.col--problem-name
  .problem__tags
    float: right

  .problem__tag
    margin: rem(0 3px 0 0) !important

